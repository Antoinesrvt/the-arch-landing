{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "outputDirectory": ".",
  "installCommand": "npm install",
  "buildCommand": "echo 'Static site - no build needed'",
  "devCommand": "npx serve . -p 3000"
}
